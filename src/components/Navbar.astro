---
import { Icon } from "astro-icon/components";

const navItems = [
	{ label: "Sobre mí", href: "#sobre-mi" },
	{ label: "Proyectos", href: "#proyectos" },
	{ label: "Experiencia", href: "#experiencia" },
	{ label: "Contacto", href: "#contacto" },
];
---

<header class="site-header">
	<nav class="nav-shell" aria-label="Navegación principal">
		<a class="nav-brand" href="#inicio" aria-label="Ir al inicio">
			Inicio
		</a>

		<button
			class="nav-toggle"
			type="button"
			aria-label="Abrir menú de navegación"
			aria-expanded="false"
			aria-controls="primary-menu"
		>
			<Icon name="tabler:menu-2" aria-hidden="true" />
		</button>

		<div class="nav-menu" id="primary-menu">
			<ul class="nav-links">
				{navItems.map((item) => (
					<li>
						<a href={item.href}>{item.label}</a>
					</li>
				))}
			</ul>

			<a class="nav-cta" href="/CV Natalia.pdf" target="_blank" rel="noopener">
				CV
			</a>
		</div>
	</nav>
</header>

<script>
	const header = document.querySelector<HTMLElement>(".site-header");
	const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
	const menu = document.querySelector<HTMLElement>(".nav-menu");
	const links = document.querySelectorAll<HTMLAnchorElement>(".nav-menu a");

	const closeMenu = () => {
		toggle?.setAttribute("aria-expanded", "false");
		toggle?.setAttribute("aria-label", "Abrir menú de navegación");
		menu?.classList.remove("is-open");
	};

	const updateHeader = () => {
		header?.classList.toggle("is-scrolled", window.scrollY > 16);
	};

	updateHeader();
	window.addEventListener("scroll", updateHeader, { passive: true });

	toggle?.addEventListener("click", () => {
		const isOpen = toggle.getAttribute("aria-expanded") === "true";
		toggle.setAttribute("aria-expanded", String(!isOpen));
		toggle.setAttribute("aria-label", isOpen ? "Abrir menú de navegación" : "Cerrar menú de navegación");
		menu?.classList.toggle("is-open", !isOpen);
	});

	links.forEach((link) => link.addEventListener("click", closeMenu));

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") closeMenu();
	});
</script>
