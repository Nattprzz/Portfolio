---
import { Icon } from "astro-icon/components";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import Layout from "../layouts/Layout.astro";

const email = "natt28.pg@gmail.com";
---

<Layout
	title="Contacto | Natalia Pérez"
	description="Formulario de contacto para escribir a Natalia Pérez."
>
	<Navbar />

	<main>
		<section class="section contact-page" aria-labelledby="form-title">
			<div class="container contact-page-grid">
				<div class="contact-page-copy reveal-on-scroll">
					<p class="section-kicker">Contacto</p>
					<h1 id="form-title">Cuéntame qué necesitas.</h1>
					<p>
						Usa este formulario para escribirme con una propuesta, consulta o colaboración. Recibiré tu nombre, correo, motivo y mensaje directamente en mi email.
					</p>

					<a class="button button-secondary" href="/#contacto">
						<Icon name="tabler:arrow-left" aria-hidden="true" />
						Volver al portfolio
					</a>
				</div>

				<form
					class="contact-form reveal-on-scroll"
					action={`https://formsubmit.co/${email}`}
					method="POST"
				>
					<input type="hidden" name="_subject" value="Nuevo mensaje desde el portfolio" />
					<input type="hidden" name="_template" value="table" />
					<input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" />

					<div class="form-field">
						<label for="name">Nombre</label>
						<input id="name" name="nombre" type="text" autocomplete="name" required />
					</div>

					<div class="form-field">
						<label for="email">Correo</label>
						<input id="email" name="email" type="email" autocomplete="email" required />
					</div>

					<div class="form-field">
						<label for="intent">Qué necesitas</label>
						<select id="intent" name="que_quiere" required>
							<option value="">Selecciona una opción</option>
							<option value="Oferta de trabajo">Oferta de trabajo</option>
							<option value="Colaboración">Colaboración</option>
							<option value="Consulta sobre un proyecto">Consulta sobre un proyecto</option>
							<option value="Otro">Otro</option>
						</select>
					</div>

					<div class="form-field">
						<label for="message">Mensaje</label>
						<textarea id="message" name="mensaje" rows="7" required></textarea>
					</div>

					<button class="button button-primary" type="submit">
						<Icon name="tabler:send" aria-hidden="true" />
						Enviar mensaje
					</button>
				</form>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
